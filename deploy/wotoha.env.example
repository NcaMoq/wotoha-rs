DISCORD_TOKEN=
RUST_LOG=info,wotoha_debug=info
WOTOHA_LOG_DIR=/var/log/wotoha
WOTOHA_LOG_FILE=wotoha-app.runtime.log
WOTOHA_LOG_ANSI=false
WOTOHA_DEFAULT_VOLUME=0.10
WOTOHA_MAX_QUEUE_LEN=512
WOTOHA_MAX_PENDING_ENQUEUES=64
WOTOHA_AUTOMIX_ENABLED=true
WOTOHA_AUTOMIX_CROSSFADE_SECONDS=8
WOTOHA_AUTOMIX_MAX_TEMPO_ADJUSTMENT=0.06
WOTOHA_AUTOMIX_MIN_BEAT_CONFIDENCE=0.70
WOTOHA_RECONNECT_STATE_FILE=/var/lib/wotoha/reconnect.json
WOTOHA_ANALYSIS_CACHE_DIR=/var/lib/wotoha/analysis
